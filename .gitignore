# OperatorOS — generated artefacts
.operatoros/
dist/
build/
*.log
.coverage
.coverage.*

# OS noise
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Node (if any module authors use JS tooling)
# package-lock.json is INTENTIONALLY tracked so CI can run `npm ci` for reproducible installs.
# Per OperatorOS maintainer policy (2026-07-04): lockfile is a build artifact, not user-data.
node_modules/
yarn.lock
pnpm-lock.yaml

# Python (Core if implemented in Python)
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Go (Core if implemented in Go)
*.test
*.out
vendor/

# Rust (Core if implemented in Rust)
target/
Cargo.lock

# Secrets — defence in depth, NOT primary scan
.env
.env.*
*.pem
*.key
id_rsa*
*.sqlite
*.sqlite-journal
*.db

# Build artefacts
oci/
terraform.tfstate*
.terraform/

# Core build artefacts
core/dist/
core/dist-bin/
core/node_modules/
core/coverage/
core/*.log
