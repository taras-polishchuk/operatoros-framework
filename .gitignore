# Node (if any module authors use JS tooling)
# package-lock.json is INTENTIONALLY tracked so CI can run `npm ci` for reproducible installs.
# Per OperatorOS maintainer policy (2026-07-04): lockfile is a build artifact, not user-data.
node_modules/
yarn.lock
pnpm-lock.yaml

# Secrets — defence in depth, NOT primary scan
.env
.env.*
*.pem
*.key
id_rsa*
*.sqlite
*.sqlite-journal
*.db

# Core build artefacts
core/dist/
core/dist-bin/
core/node_modules/
core/coverage/
core/*.log

# Auto-generated drift-detector reports (runtime output, not source)
state/drift-detector/
